# Copie para deploy/deploy-target.env (não vai para o git) e preencha.
# Depois: npm run deploy:vps  → build + envia dist/ para esta pasta no servidor.

DEPLOY_HOST=IP_OU_DOMINIO_DA_VPS
DEPLOY_USER=root
# Raiz do site no aaPanel (onde ficam index.html, assets/, env.js)
DEPLOY_PATH=/www/wwwroot/pedircacamba.com

# Opcional: chave SSH (caminho no teu PC)
# DEPLOY_SSH_KEY=C:/Users/alexm/.ssh/id_rsa
