SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
FASTSOFT_SECRET_KEY=sua_chave_fastsoft_aqui
PORT=3001

# Painel CEO (/hashadmin1): login próprio na API (cookie httpOnly). O front chama /api/ceo-auth/* e /api/ceo-dashboard.
CEO_PANEL_PASSWORD=defina_uma_senha_forte
# Opcional: se definir, o formulário pede também "utilizador" (comparação case-insensitive)
# CEO_PANEL_LOGIN=ceo
# Opcional: chave só para assinar o cookie (se mudar a senha, cookies antigos invalidam na mesma)
# CEO_PANEL_SECRET=um_segredo_longo_aleatorio

# Obrigatório em produção: URL pública HTTPS para a FastSoft avisar quando o PIX for pago.
# O checkout usa a API Node em /api/create-pix-charge — o postback deve bater no MESMO servidor:
PUBLIC_SITE_URL=https://seudominio.com
#
# Alternativa: URL completa (sobrepõe a lógica de PUBLIC_SITE_URL)
# FASTSOFT_POSTBACK_URL=https://seudominio.com/api/fastsoft-webhook
#
# Sem PUBLIC_SITE_URL, o postback ia só para a Edge Function do Supabase (tem de estar deployada).
